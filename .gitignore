## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet Packages
*.nupkg
# The packages folder can be checked into source control,
# NuGet packages
packages/
# Except build/, which is used as a temporary folder by the packages target
!packages/build/

# NuGet v3's project.json files produces outputs
project.lock.json
project.fragment.lock.json
artifacts/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# Rider cache
*.DotSettings

# Dotnet
*.nupkg
*.snupkg

# Stryker output
StrykerOutput/

# Verify received files (temporary, not committed)
*.received.*

# Verify test snapshots - committed to source control
# *.verified.txt
# *.verified.json

# OS
.DS_Store
Thumbs.db
